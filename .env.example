# MISC
NODE_ENV=development
NUXT_PUBLIC_NODE_ENV=development

# Public application origin used in completion emails.
NUXT_APP_BASE_URL=http://localhost:3000

# Runtime storage. Keep outside the source tree in production.
NUXT_STORAGE_ROOT=.chaptify-storage
NUXT_MAX_UPLOAD_BYTES=1073741824
NUXT_MAX_QUEUED_JOBS=10
NUXT_WORKER_CONCURRENCY=1
NUXT_JOB_RETENTION_HOURS=12
NUXT_EMAIL_RETRY_ATTEMPTS=3

# Mailgun. Leave blank locally when email delivery should fail safely in tests/dev.
NUXT_MAILGUN_BASE_URL=
NUXT_MAILGUN_DOMAIN=
NUXT_MAILGUN_KEY=
NUXT_MAILGUN_SENDER=
NUXT_MAILGUN_RECIPIENT=
NUXT_MAILGUN_BCC=
