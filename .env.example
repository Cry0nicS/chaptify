# MISC
NODE_ENV=development

# Public application origin used in completion emails (e.g. https://chaptify.org).
# Not to be confused with Nuxt's reserved NUXT_APP_BASE_URL (a route path prefix).
NUXT_SITE_URL=http://localhost:3000

# Runtime storage. Keep outside the source tree in production.
NUXT_STORAGE_ROOT=.chaptify-storage
NUXT_MAX_UPLOAD_BYTES=1610612736
NUXT_MAX_QUEUED_JOBS=10
NUXT_MAX_CONCURRENT_UPLOADS=2
# Abort an upload after this many seconds of no received data (anti-slowloris).
NUXT_UPLOAD_IDLE_TIMEOUT_SECONDS=30
# Trusted-proxy policy for resolving the client IP used by per-IP rate limits.
# Empty/false: trust only the direct connection (safe default, no reverse proxy).
# true: single trusted proxy; use the right-most X-Forwarded-For hop.
# Comma-separated IPs/IPv4 CIDRs (e.g. "127.0.0.1,::1,172.16.0.0/12"): trust
# X-Forwarded-For only when the peer is a listed proxy. The proxy MUST set
# (not merely append) X-Forwarded-For for this to be safe.
NUXT_TRUST_PROXY=
NUXT_PER_IP_UPLOAD_LIMIT=5
NUXT_PER_IP_JOB_LIMIT=5
NUXT_DOWNLOAD_RATE_LIMIT=30
NUXT_STORAGE_RESERVATION_MULTIPLIER=4
NUXT_STORAGE_RESERVATION_SAFETY_BYTES=268435456
NUXT_STORAGE_RESERVATION_TTL_MINUTES=120
NUXT_ORPHAN_JOB_DIRECTORY_MIN_AGE_MINUTES=30
NUXT_CLEANUP_INTERVAL_SECONDS=300
NUXT_BROWSER_DOWNLOAD_GRANT_LIFETIME_SECONDS=60
NUXT_BROWSER_DOWNLOAD_GRANT_USED_GRACE_SECONDS=300
NUXT_WORKER_CONCURRENCY=1
NUXT_JOB_RETENTION_HOURS=12
NUXT_MAX_AUDIOBOOK_DURATION_SECONDS=108000
NUXT_MAX_CHAPTERS=300
NUXT_JOB_PROCESSING_TIMEOUT_SECONDS=14400
NUXT_FFPROBE_TIMEOUT_SECONDS=30
NUXT_FFMPEG_CHAPTER_TIMEOUT_SECONDS=1200
NUXT_EMAIL_RETRY_ATTEMPTS=3
NUXT_EMAIL_RETRY_BASE_DELAY_SECONDS=60
NUXT_EMAIL_RETRY_MAX_DELAY_SECONDS=3600

# Server-only signing secret for restart-safe emailed download links.
# Use at least 32 random characters in any environment that sends email.
NUXT_DOWNLOAD_SIGNING_SECRET=

# Mailgun. Leave blank locally when email delivery should fail safely in tests/dev.
NUXT_MAILGUN_BASE_URL=
NUXT_MAILGUN_DOMAIN=
NUXT_MAILGUN_KEY=
NUXT_MAILGUN_SENDER=
NUXT_MAILGUN_BCC=

# Contact form. Submissions are emailed to this inbox via Mailgun; leave blank to disable.
NUXT_CONTACT_RECIPIENT=
# Messages allowed per IP per hour.
NUXT_CONTACT_RATE_LIMIT=5
